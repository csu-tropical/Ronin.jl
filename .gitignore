# Julia ----------------------------------------------------------------------
# Manifest.toml is intentionally not tracked for libraries — it pins exact
# versions for development, but releases need the bounds in [compat] to be
# the source of truth. Remove this rule if Ronin ever becomes an end-user
# application that benefits from a reproducible Manifest.
Manifest.toml
deps/build.log
deps/deps.jl
docs/build/
docs/site/
*.cov
*.mem
.julia-cache/

# OS / editors ---------------------------------------------------------------
.DS_Store
.ipynb_checkpoints/
*.swp
*~

# Jupyter --------------------------------------------------------------------
.ipynb_checkpoints/

# CondaPkg -------------------------------------------------------------------
.CondaPkg/

